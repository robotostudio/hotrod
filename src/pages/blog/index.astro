---
import BaseLayout from '../../layouts/base-layout.astro';
import CheckerboardDivider from '../../components/checkerboard-divider.astro';
import Lucide from '../../components/lucide.astro';
import { getPublishedPosts } from '../../lib/content';
import { formatDate } from '../../lib/format-date';
import { readingTime } from '../../lib/reading-time';
import { getEntry } from 'astro:content';

const posts = await getPublishedPosts();
const featured = posts.find((post) => post.data.featured);
const regular = posts.filter((post) => !post.data.featured);

const authorsById = new Map<string, string>();
for (const post of posts) {
  if (authorsById.has(post.data.author.id)) continue;
  const author = await getEntry(post.data.author);
  if (!author) {
    throw new Error(
      `Post "${post.id}" references author "${post.data.author.id}" which does not exist in src/content/authors/.`,
    );
  }
  authorsById.set(author.id, author.data.name);
}

function authorName(id: string): string {
  const name = authorsById.get(id);
  if (!name) throw new Error(`Missing author lookup for "${id}".`);
  return name;
}

function category(tags: readonly string[]): string | null {
  return tags[0] ? tags[0].toUpperCase() : null;
}
---

<BaseLayout title="Blog" description="Writing from the Hotrod team.">
  <section class="bg-background text-foreground py-20 px-6">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-6xl md:text-7xl font-black mb-4 tracking-tight">BLOG</h1>
      <p class="text-xl md:text-2xl font-semibold max-w-2xl mx-auto">
        Writing from the Hotrod team.
      </p>
    </div>
  </section>

  {featured && (
    <>
      <CheckerboardDivider />
      <section class="bg-foreground text-background py-20 px-6">
        <div class="mx-auto max-w-7xl">
          <div class="flex items-center gap-4 mb-8">
            <span class="bg-background text-foreground px-4 py-2 font-black text-sm">
              FEATURED
            </span>
            <div class="h-1 flex-1 bg-background" />
          </div>
          <a
            href={`/blog/${featured.id}`}
            class="block bg-background text-foreground border-4 border-background hover:border-white transition-colors p-8 md:p-12"
          >
            {category(featured.data.tags) && (
              <span class="inline-block bg-foreground text-background px-3 py-1 font-bold text-sm mb-4">
                {category(featured.data.tags)}
              </span>
            )}
            <h2 class="text-4xl md:text-5xl font-black mb-4 tracking-tight">
              {featured.data.title.toUpperCase()}
            </h2>
            <p class="text-lg md:text-xl font-semibold mb-6 opacity-90 max-w-3xl">
              {featured.data.description}
            </p>
            <div class="flex flex-wrap items-center gap-6 text-sm font-bold">
              <span class="flex items-center gap-2">
                <Lucide name="user" class="w-4 h-4" />
                {authorName(featured.data.author.id)}
              </span>
              <span class="flex items-center gap-2">
                <Lucide name="calendar" class="w-4 h-4" />
                {formatDate(featured.data.publishedAt)}
              </span>
              <span class="flex items-center gap-2">
                <Lucide name="clock" class="w-4 h-4" />
                {readingTime(featured.body)}
              </span>
            </div>
            <div class="mt-8 flex items-center gap-2 font-black text-lg">
              READ ARTICLE <Lucide name="arrow-right" class="w-5 h-5" />
            </div>
          </a>
        </div>
      </section>
      <CheckerboardDivider />
    </>
  )}

  <section class="bg-background text-foreground py-20 px-6">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-center gap-4 mb-12">
        <span class="bg-foreground text-background px-4 py-2 font-black text-sm">
          LATEST POSTS
        </span>
        <div class="h-1 flex-1 bg-foreground" />
      </div>
      {regular.length === 0 ? (
        <p class="font-semibold">No posts yet.</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {regular.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="block bg-foreground text-background border-4 border-foreground hover:border-white transition-colors p-6 h-full"
            >
              {category(post.data.tags) && (
                <span class="inline-block bg-background text-foreground px-3 py-1 font-bold text-xs mb-4 self-start">
                  {category(post.data.tags)}
                </span>
              )}
              <h3 class="text-xl font-black mb-3 tracking-tight">
                {post.data.title.toUpperCase()}
              </h3>
              <p class="font-medium opacity-90 mb-4">{post.data.description}</p>
              <div class="flex flex-wrap items-center gap-4 text-xs font-bold opacity-80 mb-4">
                <span class="flex items-center gap-1">
                  <Lucide name="calendar" class="w-3 h-3" />
                  {formatDate(post.data.publishedAt)}
                </span>
                <span class="flex items-center gap-1">
                  <Lucide name="clock" class="w-3 h-3" />
                  {readingTime(post.body)}
                </span>
              </div>
              <div class="flex items-center gap-2 font-black text-sm">
                READ MORE <Lucide name="arrow-right" class="w-4 h-4" />
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <CheckerboardDivider />

  <section class="bg-foreground text-background py-20 px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-4xl md:text-5xl font-black mb-4">STAY IN THE LOOP</h2>
      <p class="text-lg font-semibold mb-8 opacity-90">
        Get new posts delivered straight to your inbox.
      </p>
      <form
        method="post"
        action="#"
        class="flex flex-col sm:flex-row gap-4 justify-center max-w-xl mx-auto"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="Enter your email"
          class="flex-1 px-6 py-4 bg-background text-foreground font-bold placeholder:text-foreground/60 border-4 border-background focus:outline-none focus:border-white"
        />
        <button
          type="submit"
          class="bg-background text-foreground hover:bg-background/90 font-bold text-lg px-8 py-4"
        >
          SUBSCRIBE
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
