---
import BaseLayout from './base-layout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = {
  author: CollectionEntry<'authors'>;
  posts: CollectionEntry<'blog'>[];
};

const { author, posts } = Astro.props;
const { name, role, shortBio, social } = author.data;

const baseUrl = Astro.site ?? Astro.url;
const profileUrl = new URL(`/authors/${author.id}/`, baseUrl).toString();
const sameAs = [
  social.twitter && `https://twitter.com/${social.twitter}`,
  social.github && `https://github.com/${social.github}`,
  social.linkedin && `https://linkedin.com/in/${social.linkedin}`,
  social.website,
].filter((href): href is string => Boolean(href));

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  url: profileUrl,
  description: shortBio,
  ...(role ? { jobTitle: role } : {}),
  ...(sameAs.length > 0 ? { sameAs } : {}),
};

const metaDescription = `${shortBio}${role ? ` ${role} at Roboto Studio.` : ''} Writing on Hotrod — the agent-first Astro starter for agent-edited marketing sites.`;
---

<BaseLayout
  title={name}
  description={shortBio}
  metaDescription={metaDescription}
  jsonLd={personJsonLd}
>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <article class="prose">
      <h1>{name}</h1>
      {role && <p class="text-sm font-bold uppercase tracking-wide">{role}</p>}
      <p class="lead">{shortBio}</p>
      <slot />
      {Object.keys(social).length > 0 && (
        <ul>
          {social.twitter && <li><a href={`https://twitter.com/${social.twitter}`}>Twitter</a></li>}
          {social.github && <li><a href={`https://github.com/${social.github}`}>GitHub</a></li>}
          {social.linkedin && <li><a href={`https://linkedin.com/in/${social.linkedin}`}>LinkedIn</a></li>}
          {social.website && <li><a href={social.website}>Website</a></li>}
        </ul>
      )}
    </article>
    {posts.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-black tracking-tight">Posts by {name}</h2>
        <ul class="mt-4 space-y-3">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="font-bold hover:underline underline-offset-4">
                {post.data.title}
              </a>
              <p class="text-sm font-medium">{post.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>
