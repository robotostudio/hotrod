---
import '../styles/global.css';
import { Font } from 'astro:assets';
import CheckerboardDivider from '../components/checkerboard-divider.astro';
import SiteNav from '../components/site-nav.astro';
import SiteFooter from '../components/site-footer.astro';

type Props = {
  title: string;
  description: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  updatedAt?: Date;
  markdownHref?: string;
};

const SITE_NAME = 'Hotrod';

const {
  title,
  description,
  type = 'website',
  publishedAt,
  updatedAt,
  markdownHref,
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '');
const isHome = pathname === '';
const ogSlug = isHome ? 'index' : pathname.replace(/^\//, '');
const baseUrl = Astro.site ?? Astro.url;
const ogImageUrl = new URL(`/og/${ogSlug}.png`, baseUrl).toString();
const canonicalUrl = new URL(pathname === '' ? '/' : `${pathname}/`, baseUrl).toString();
const fullTitle = isHome ? title : `${title} | ${SITE_NAME}`;
const ogImageAlt = isHome ? title : `${title} — ${SITE_NAME}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFD700" />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {type === 'article' && updatedAt && (
      <meta property="article:modified_time" content={updatedAt.toISOString()} />
    )}
    {markdownHref && (
      <link rel="alternate" type="text/markdown" href={markdownHref} />
    )}
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <SiteNav />

    <CheckerboardDivider />

    <main class="min-h-[60vh]">
      <slot />
    </main>

    <SiteFooter />

    <CheckerboardDivider />
  </body>
</html>
