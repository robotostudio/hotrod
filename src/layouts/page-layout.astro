---
import BaseLayout from './base-layout.astro';

type Props = {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
};

const { title, description, publishedAt, updatedAt } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <article class="prose prose-slate">
    <h1>{title}</h1>
    <slot />
  </article>
</BaseLayout>
